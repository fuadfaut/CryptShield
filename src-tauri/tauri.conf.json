{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CryptShield",
  "version": "0.1.5",
  "identifier": "com.fuadfaut.cryptshield",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CryptShield - DNSCrypt GUI",
        "width": 1100,
        "height": 700,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420"
    }
  },
  "bundle": {
    "license": "MIT",
    "active": true,
    "targets": ["appimage", "rpm"],
    "linux": {
      "rpm": {
        "depends": ["dnscrypt-proxy", "NetworkManager", "polkit"],
        "files": {
          "/usr/share/polkit-1/actions/com.fuadfaut.cryptshield.policy": "polkit/com.fuadfaut.cryptshield.policy"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
